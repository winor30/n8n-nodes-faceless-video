{
  "name": "n8n-nodes-faceless-video",
  "version": "0.1.7",
  "description": "n8n community node to generate captioned, voiced 9:16/1:1/16:9 videos via the Faceless Video API",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "author": {
    "name": "winor30",
    "email": "tk.30.r.h@gmail.com"
  },
  "homepage": "https://github.com/winor30/n8n-nodes-faceless-video",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winor30/n8n-nodes-faceless-video.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "prepublishOnly": "pnpm run format:check && pnpm run lint && pnpm run build && pnpm test",
    "test": "echo \"No tests configured\""
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/FacelessVideoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FacelessVideo/FacelessVideo.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.32.1",
    "eslint": "9.29.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.5.0"
}
